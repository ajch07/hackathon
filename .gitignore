# CogniTrack - Root .gitignore

# Windows special files
NUL

# Environment variables (CRITICAL - contains secrets!)
.env
.env.local
.env.production
.env.development
*.env

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
venv/
ENV/
env/
.venv/

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.local
dist/
dist-ssr/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
*.suo
*.ntvs*
*.njsproj
*.sln

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage/

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db
*.DS_Store

# Build artifacts
*.pyc
*.pyo
*.pyd

# Temporary files
*.tmp
*.temp
.cache/
